{
  "manifest_version": 3,
  "name": "Vim Diesel",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "tabs", "scripting", "alarms", "clipboardRead"],
  "host_permissions": ["http://localhost:8000/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Vim Diesel"
  }
}
