{
  "name": "personal-workflow-agent-extension",
  "displayName": "Personal Workflow Agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "manifest": {
    "host_permissions": [
      "http://127.0.0.1:8000/*",
      "http://localhost:8000/*",
      "https://*/*",
      "http://*/*"
    ],
    "permissions": [
      "storage",
      "activeTab",
      "tabs",
      "scripting",
      "alarms",
      "clipboardRead"
    ]
  },
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "typecheck": "tsc --noEmit",
    "showcase:launch": "node scripts/showcase-launch.mjs"
  },
  "dependencies": {
    "plasmo": "^0.90.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rrweb": "^2.0.0-alpha.18"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "playwright": "^1.59.1",
    "typescript": "^5.6.3"
  }
}
